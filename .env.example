# ===== APPLICATION =====
APP_NAME=Prodaxis WhatsApp Platform
APP_ENV=development
APP_VERSION=0.1.0
APP_PORT=8000
APP_HOST=0.0.0.0
APP_DEBUG=True
APP_BASE_URL=http://localhost:8000

# ===== SECURITY =====
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
API_KEY=change-me-generate-with-secrets-token-urlsafe-32

# ===== DATABASE (Supabase PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_ECHO=False
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prodaxis_test

# ===== REDIS (Upstash) =====
REDIS_URL=rediss://default:password@xxx.upstash.io:6379
REDIS_MAX_CONNECTIONS=50

# ===== CELERY =====
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# ===== META WHATSAPP CLOUD API =====
META_API_VERSION=v22.0
META_API_BASE_URL=https://graph.facebook.com
META_APP_ID=1917587308885997
META_APP_SECRET=your-app-secret-here
META_BUSINESS_PORTFOLIO_ID=1520595226449789
META_WABA_ID=114828481581164
META_PHONE_NUMBER_ID=your-production-phone-number-id
META_ACCESS_TOKEN=your-permanent-system-user-token
META_WEBHOOK_VERIFY_TOKEN=prodaxis_webhook_secret_2026_change_me

# ===== RATE LIMITING (Meta Limits) =====
META_MAX_MESSAGES_PER_SECOND=80
META_MAX_PER_RECIPIENT_PER_6_SECONDS=1
META_MAX_BURST_PER_RECIPIENT=45

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/prodaxis.log
LOG_ROTATION=100 MB
LOG_RETENTION=30 days

# ===== SENTRY (Error Monitoring) =====
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://prodaxis.in

# ===== TENANT (Single-tenant mode for now) =====
DEFAULT_TENANT_ID=prodaxis-default
DEFAULT_TENANT_NAME=Prodaxis
DEFAULT_TENANT_SLUG=prodaxis
ENABLE_MULTI_TENANT=False

# ===== ENCRYPTION (for tenant access tokens) =====
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-a-fernet-key-here
